<footer class="bg-ink-950 text-cream-200 pt-16 pb-8">
  <div class="container">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-12">
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="font-display text-2xl font-semibold text-cream-50 block mb-4">{{ store.name }}</a>
        <p class="text-sm text-ink-400">{{ store.description }}</p>
      </div>
      {% for group in ["shop","support","company"] %}
      <div>
        <h4 class="font-medium text-cream-50 mb-4">{{ trans("footer." ~ group) }}</h4>
        <ul class="space-y-2">
          {% for item in menus["footer_" ~ group] %}
            <li><a href="{{ item.url }}" class="text-sm text-ink-400 hover:text-cream-50 transition-colors">{{ item.name }}</a></li>
          {% endfor %}
        </ul>
      </div>
      {% endfor %}
    </div>
    <div class="border-t border-ink-800 pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-sm text-ink-500">© {{ "now"|date("Y") }} {{ store.name }}</p>
      <salla-social-links></salla-social-links>
    </div>
  </div>
</footer>
