<header class="sticky top-0 z-40 bg-cream-50/95 backdrop-blur-sm border-b border-ink-100" x-data="{open:false}" :class="{'shadow-soft': $store.ui.scrolled}">
  <div class="container h-20 flex items-center justify-between gap-6">
    <a href="/" class="font-display text-2xl font-semibold">{{ store.name }}</a>
    <nav class="hidden lg:flex items-center gap-8">
      {% for item in menus.header %}
        <a href="{{ item.url }}" class="text-sm font-medium text-ink-600 hover:text-ink-900 transition-colors">{{ item.name }}</a>
      {% endfor %}
    </nav>
    <div class="flex items-center gap-3">
      <button @click="$dispatch('open-search')" class="btn-icon"><svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M21 21l-5.197-5.197A7.5 7.5 0 1 0 5.196 5.196L21 21z"/></svg></button>
      <button @click="$dispatch('open-cart')" class="btn-icon relative"><svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 0 0-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 0 0-16.536-1.84M7.5 14.25 5.106 5.272M6 20.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Zm12.75 0a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z"/></svg><span x-show="$store.cart.count > 0" x-text="$store.cart.count" class="absolute -top-1 -end-1 w-4 h-4 bg-accent text-cream-50 rounded-full text-xs flex items-center justify-center"></span></button>
    </div>
  </div>
</header>
