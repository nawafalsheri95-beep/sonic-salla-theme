<div x-data="{open:false}" @open-cart.window="open=true" @keydown.escape.window="open=false">
  <div x-show="open" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="translate-x-full" x-transition:enter-end="translate-x-0" class="fixed inset-y-0 end-0 w-full max-w-sm bg-cream-50 shadow-lift z-50 flex flex-col">
    <div class="flex items-center justify-between px-6 py-4 border-b border-ink-100">
      <h2 class="font-display text-xl">{{ trans("cart.title") }} (<span x-text="$store.cart.count">0</span>)</h2>
      <button @click="open=false" class="btn-icon"><svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M6 18L18 6M6 6l12 12"/></svg></button>
    </div>
    <div class="flex-1 overflow-y-auto p-6">
      <template x-if="$store.cart.count === 0">
        <p class="text-center text-ink-400 py-12">{{ trans("cart.empty") }}</p>
      </template>
      <salla-cart-summary></salla-cart-summary>
    </div>
    <div class="p-6 border-t border-ink-100">
      <a :href="$store.cart.checkoutUrl" class="btn-primary w-full justify-center">{{ trans("cart.checkout") }}</a>
    </div>
  </div>
  <div x-show="open" @click="open=false" class="fixed inset-0 bg-ink-950/40 z-40 backdrop-blur-sm"></div>
</div>
