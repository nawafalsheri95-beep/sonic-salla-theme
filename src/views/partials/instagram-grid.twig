{% if setting("instagram_enabled") %}
<section class="container py-16" data-reveal>
  <h2 class="font-display text-4xl text-center mb-8">{{ setting("instagram_handle", "@yourstore") }}</h2>
  <div class="grid grid-cols-3 md:grid-cols-6 gap-2">
    {% for post in instagram_posts %}
    <a href="{{ post.url }}" target="_blank" class="aspect-square overflow-hidden rounded-lg group">
      <img src="{{ post.image }}" alt="{{ post.caption }}" loading="lazy" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110">
    </a>
    {% endfor %}
  </div>
</section>
{% endif %}
