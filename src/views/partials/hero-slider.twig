<section class="relative overflow-hidden rounded-3xl mx-4 mt-4" style="height:90vh">
  <salla-slider autoplay="6000" loop="true">
    {% for slide in slides %}
    <div class="relative h-full">
      <img src="{{ slide.image }}" alt="{{ slide.title }}" class="w-full h-full object-cover">
      <div class="absolute inset-0 bg-gradient-to-t from-ink-950/60 to-transparent flex items-end pb-16 px-12">
        <div class="text-cream-50 max-w-xl">
          <p class="text-sm tracking-widest uppercase mb-3 opacity-75">{{ slide.subtitle }}</p>
          <h2 class="font-display text-6xl font-light leading-none mb-6">{{ slide.title }}</h2>
          <a href="{{ slide.url }}" class="btn-secondary">{{ slide.cta }}</a>
        </div>
      </div>
    </div>
    {% endfor %}
  </salla-slider>
</section>
